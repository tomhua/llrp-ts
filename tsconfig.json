{
  "compilerOptions": {
    "outDir": "dist",
    "module": "node16",
    "target": "es2020",
    "sourceMap": true,
    "moduleResolution": "node16",
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ],
  "compileOnSave": true,
  "watch": true,
  "sourceMap": true
}